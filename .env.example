# ============================================================
# ЕГЭ AI backend — переменные окружения (шаблон)
# Скопируйте в .env и заполните. .env в git не коммитится.
# ============================================================

# --- App ---
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGIN=http://localhost:5173

# --- Database (Supabase Postgres сейчас → self-hosted Postgres после MVP) ---
# DATABASE_URL — пул-соединение (Supabase pooler, порт 6543, pgbouncer)
# DIRECT_URL   — прямое соединение для миграций (Supabase, порт 5432)
# При миграции на self-hosted Postgres достаточно поменять обе строки.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# --- Auth (собственный JWT, не Supabase Auth, чтобы миграция не ломала вход) ---
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900            # 15 минут
JWT_REFRESH_TTL=2592000       # 30 дней

# --- Redis (очередь BullMQ для дорогих ИИ-задач: фото, сочинения, генерация плана) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- AI providers (включите тот, для которого есть ключ) ---
# Claude API — https://console.anthropic.com
ANTHROPIC_API_KEY=
AI_MODEL_FAST=claude-haiku-4-5-20251001       # дёшево: автопроверка, короткие подсказки
AI_MODEL_SMART=claude-sonnet-4-6              # основной: проверка сочинений, план
AI_MODEL_HEAVY=claude-opus-4-8               # сложное: спорные разборы, фото-задания
# OpenAI API — https://platform.openai.com (ChatGPT Plus НЕ даёт API-ключ!)
OPENAI_API_KEY=
OPENAI_MODEL_SMART=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini
# Провайдер по умолчанию: anthropic | openai
AI_DEFAULT_PROVIDER=anthropic

# --- Storage (Supabase Storage сейчас → S3 после MVP, за интерфейсом StorageService) ---
STORAGE_DRIVER=supabase       # supabase | s3 | local
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=uploads

# --- Payments (webhook-based, ЮKassa как пример для РФ) ---
PAYMENTS_PROVIDER=yookassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=

# --- Notifications ---
TELEGRAM_BOT_TOKEN=
SMTP_URL=
